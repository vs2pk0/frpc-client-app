{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FRPC Tunnel Manager",
  "version": "0.1.0",
  "identifier": "com.dalong.frpc.tunnel-manager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "FRPC Tunnel Manager",
        "width": 1120,
        "height": 760,
        "minWidth": 900,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "msi", "nsis"],
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "resources": {
      "resources/frpc/darwin-arm64/frpc": "resources/frpc/darwin-arm64/frpc",
      "resources/defaults/frpc.toml": "resources/defaults/frpc.toml"
    },
    "macOS": {
      "minimumSystemVersion": "12.0"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  },
  "plugins": {}
}
